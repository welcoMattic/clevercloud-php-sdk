{
    "name": "clevercloud/sdk",
    "description": "PHP SDK for the Clever Cloud REST API (v2 + v4).",
    "license": "MIT",
    "type": "library",
    "keywords": ["clever-cloud", "sdk", "api", "paas", "oauth1"],
    "homepage": "https://github.com/welcoMattic/clevercloud-php-sdk",
    "require": {
        "php": ">=8.5",
        "ext-hash": "*",
        "ext-json": "*",
        "jolicode/automapper": "^10.0",
        "nyholm/psr7": "^1.8",
        "psr/clock": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0",
        "symfony/clock": "^7.0 || ^8.0",
        "symfony/http-client": "^7.2 || ^8.0",
        "symfony/http-client-contracts": "^3.5 || ^4.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "CleverCloud\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CleverCloud\\Sdk\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "check": ["@cs", "@phpstan", "@test"]
    },
    "minimum-stability": "stable"
}
