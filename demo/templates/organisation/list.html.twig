{% extends 'base.html.twig' %}

{% block title %}Organisations — Clever Cloud Dashboard{% endblock %}
{% block page_title %}Organisations{% endblock %}
{% block page_subtitle %}
    <p class="topbar__subtitle">{{ organisations|length }} organisation{{ organisations|length > 1 ? 's' }} accessibles</p>
{% endblock %}

{% block body %}
    <div class="card">
        {% if organisations is empty %}
            <p class="card__empty">Aucune organisation.</p>
        {% else %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>ID</th>
                        <th>Pays</th>
                        <th>Statut TVA</th>
                        <th>Création</th>
                        <th class="table__actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for orga in organisations %}
                        <tr>
                            <td><strong>{{ orga.name }}</strong></td>
                            <td><span class="table__id">{{ orga.id }}</span></td>
                            <td>{{ orga.country ?? '—' }}</td>
                            <td>
                                {% if orga.vatState %}
                                    <span class="badge {% if orga.vatState == 'VALID' %}ok{% else %}warn{% endif %}">{{ orga.vatState }}</span>
                                {% else %}—{% endif %}
                            </td>
                            <td>
                                {% if orga.creationDate %}
                                    {{ (orga.creationDate / 1000)|round(0, 'floor')|date('Y-m-d') }}
                                {% else %}—{% endif %}
                            </td>
                            <td class="table__actions">
                                <div class="btn-group">
                                    <a class="btn btn--sm" href="{{ path('application_list', { owner: orga.id }) }}">Apps</a>
                                    <a class="btn btn--sm" href="{{ path('addon_list', { owner: orga.id }) }}">Add-ons</a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
