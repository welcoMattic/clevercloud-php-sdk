{% extends 'base.html.twig' %}

{% block title %}Accueil — Clever Cloud Dashboard{% endblock %}
{% block page_title %}Bonjour {{ me.firstname ?? me.email }}{% endblock %}
{% block page_subtitle %}
    <p class="topbar__subtitle">
        <span class="table__id">{{ me.id }}</span>
        {% if me.email %} · {{ me.email }}{% endif %}
    </p>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Tes organisations{% if organisations %} <span class="badge neutral">{{ organisations|length }}</span>{% endif %}</h3>
        </div>
        {% if organisations is empty %}
            <p class="card__empty">Aucune organisation rattachée à ce compte.</p>
        {% else %}
            <table class="table">
                <thead><tr><th>Nom</th><th>ID</th><th class="table__actions">Actions</th></tr></thead>
                <tbody>
                    {% for orga in organisations %}
                        <tr>
                            <td><strong>{{ orga.name }}</strong></td>
                            <td><span class="table__id">{{ orga.id }}</span></td>
                            <td class="table__actions">
                                <div class="btn-group">
                                    <a class="btn btn--sm" href="{{ path('application_list', { owner: orga.id }) }}">Apps</a>
                                    <a class="btn btn--sm" href="{{ path('addon_list', { owner: orga.id }) }}">Add-ons</a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    <div class="card">
        <div class="card__header"><h3 class="card__title">Espace personnel</h3></div>
        <div class="card__body">
            <div class="btn-group">
                <a class="btn btn--primary" href="{{ path('application_list') }}">Mes apps</a>
                <a class="btn btn--primary" href="{{ path('addon_list') }}">Mes add-ons</a>
            </div>
        </div>
    </div>
{% endblock %}
