{% extends 'base.html.twig' %}

{% block title %}Erreur — Clever Cloud Dashboard{% endblock %}
{% block page_title %}Erreur lors de l'appel API{% endblock %}

{% block body %}
    <div class="card card--warn">
        <div class="card__body">
            <p class="card__error">{{ exception.getMessage() }}</p>
            <p class="form-help" style="margin-top: 1rem;">
                Vérifie l'authentification — soit un <code class="code">CC_API_TOKEN</code> valide, soit
                un consumer + token utilisateur OAuth 1.0a obtenu via <a href="{{ path('login') }}">/login</a>.
            </p>
            <div class="btn-group" style="margin-top: 1rem;">
                <a class="btn btn--primary" href="{{ path('dashboard') }}">Retour à l'accueil</a>
                <a class="btn" href="{{ path('login') }}">Se reconnecter</a>
            </div>
        </div>
    </div>
{% endblock %}
