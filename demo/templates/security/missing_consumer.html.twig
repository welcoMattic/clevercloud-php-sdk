{% extends 'base.html.twig' %}

{% block title %}Configuration manquante — Clever Cloud Dashboard{% endblock %}
{% block page_title %}Credentials manquants{% endblock %}

{% block body %}
    <div class="card card--warn">
        <div class="card__body">
            <p>
                Pour initier le flow OAuth, il faut renseigner
                <code class="code">CC_CONSUMER_KEY</code> et <code class="code">CC_CONSUMER_SECRET</code>
                dans <code class="code">.env.local</code>.
            </p>
            <p class="form-help">
                Récupère-les sur <a href="https://www.clever.cloud/doc/extend/cc-api/">la doc Clever Cloud</a>.
            </p>
        </div>
    </div>
{% endblock %}
