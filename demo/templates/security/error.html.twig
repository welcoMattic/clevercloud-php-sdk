{% extends 'base.html.twig' %}

{% block title %}Erreur OAuth{% endblock %}

{% block body %}
    <div class="card">
        <h2>Échec du flow OAuth</h2>
        <pre style="background: #f3f4f6; padding: 1rem; border-radius: 4px; overflow-x: auto;">{{ exception.getMessage() }}</pre>
        <p>
            <a class="btn primary" href="{{ path('login') }}">Réessayer</a>
        </p>
    </div>
{% endblock %}
