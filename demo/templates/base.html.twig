<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Clever Cloud Dashboard{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>☁️</text></svg>">
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </head>
    <body>
        {% block layout %}
            <div class="app-shell">
                <aside class="sidebar">
                    <div class="sidebar__brand">
                        <span class="sidebar__brand-icon">☁️</span>
                        <span>Clever Cloud</span>
                    </div>

                    <div class="sidebar__section">
                        <p class="sidebar__section-title">Dashboard</p>
                        <a class="sidebar__link {{ app.request.attributes.get('_route') == 'dashboard' ? 'is-active' }}" href="{{ path('dashboard') }}">
                            <span class="sidebar__link-icon">⌂</span> Accueil
                        </a>
                        <a class="sidebar__link {{ app.request.attributes.get('_route') starts with 'organisation_' ? 'is-active' }}" href="{{ path('organisation_list') }}">
                            <span class="sidebar__link-icon">⌬</span> Organisations
                        </a>
                    </div>

                    <div class="sidebar__section">
                        <p class="sidebar__section-title">Workloads</p>
                        <a class="sidebar__link {{ app.request.attributes.get('_route') starts with 'application_' ? 'is-active' }}" href="{{ path('application_list') }}">
                            <span class="sidebar__link-icon">▣</span> Applications
                        </a>
                        <a class="sidebar__link {{ app.request.attributes.get('_route') starts with 'addon_' ? 'is-active' }}" href="{{ path('addon_list') }}">
                            <span class="sidebar__link-icon">◈</span> Add-ons
                        </a>
                    </div>

                    <div class="sidebar__section">
                        <p class="sidebar__section-title">Sécurité</p>
                        <a class="sidebar__link {{ app.request.attributes.get('_route') starts with 'api_tokens_' ? 'is-active' }}" href="{{ path('api_tokens_list') }}">
                            <span class="sidebar__link-icon">⚿</span> API tokens
                        </a>
                    </div>

                    <div class="sidebar__footer">
                        {% if app.session.has('cc_api_token') %}
                            <span class="sidebar__auth-mode sidebar__auth-mode--bearer">Bearer</span>
                            <form method="post" action="{{ path('logout') }}" class="inline">
                                <button type="submit" class="sidebar__logout">Déconnexion</button>
                            </form>
                        {% elseif app.session.has('cc_user_token') %}
                            <span class="sidebar__auth-mode sidebar__auth-mode--oauth">OAuth 1.0a</span>
                            <form method="post" action="{{ path('logout') }}" class="inline">
                                <button type="submit" class="sidebar__logout">Déconnexion</button>
                            </form>
                        {% else %}
                            <a class="sidebar__logout" href="{{ path('login') }}">Connexion</a>
                        {% endif %}
                    </div>
                </aside>

                <div class="main">
                    {% block topbar %}
                        <div class="topbar">
                            <div class="topbar__inner">
                                <div>
                                    <h1 class="topbar__title">{% block page_title %}Dashboard{% endblock %}</h1>
                                    {% block page_subtitle %}{% endblock %}
                                </div>
                                {% block topbar_actions %}{% endblock %}
                            </div>
                        </div>
                    {% endblock %}

                    <div class="app-content">
                        {% for label, messages in app.flashes %}
                            {% for message in messages %}
                                <div class="flash {{ label }}">{{ message }}</div>
                            {% endfor %}
                        {% endfor %}
                        {% block body %}{% endblock %}
                    </div>
                </div>
            </div>
        {% endblock %}
    </body>
</html>
