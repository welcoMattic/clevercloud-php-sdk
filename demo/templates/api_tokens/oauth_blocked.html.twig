{% extends 'base.html.twig' %}

{% block title %}API tokens — Clever Cloud Dashboard{% endblock %}

{% block body %}
    <div class="card" style="border-left: 4px solid #f59e0b;">
        <h2>API tokens indisponibles dans ce mode</h2>
        <p>
            La gestion des tokens passe par <code>api-bridge.clever-cloud.com</code>, qui n'accepte
            que l'authentification <strong>Bearer</strong>. Tu es actuellement connecté en OAuth 1.0a.
        </p>
        <p>
            Pour utiliser cette page :
        </p>
        <ol>
            <li>Mint un token initial depuis la <a href="https://console.clever-cloud.com/" target="_blank" rel="noopener">Console Clever Cloud</a> (section <em>Personal API tokens</em>).</li>
            <li>Déconnecte-toi puis reconnecte-toi via <em>API token</em>.</li>
        </ol>
        <div style="display: flex; gap: 0.5rem;">
            <form class="inline" method="post" action="{{ path('logout') }}">
                <button class="btn primary" type="submit">Se déconnecter</button>
            </form>
            <a class="btn" href="{{ path('dashboard') }}">Retour à l'accueil</a>
        </div>
    </div>
{% endblock %}
