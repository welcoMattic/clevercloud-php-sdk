{% extends 'base.html.twig' %}

{% block title %}Applications — Clever Cloud Dashboard{% endblock %}
{% block page_title %}Applications{% endblock %}
{% block page_subtitle %}
    <p class="topbar__subtitle">{{ applications|length }} application{{ applications|length > 1 ? 's' }} dans le contexte sélectionné</p>
{% endblock %}
{% block topbar_actions %}
    <a class="btn btn--primary" href="{{ path('application_new', selectedOwner ? { owner: selectedOwner } : {}) }}">+ Nouvelle application</a>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card__body">
            <form method="get" action="{{ path('application_list') }}" class="owner-filter">
                <label class="form-field__label" for="owner-select">Propriétaire</label>
                <select id="owner-select" name="owner" class="form-field__select" onchange="this.form.submit()">
                    <option value="self" {% if selectedOwner is null %}selected{% endif %}>Moi (self)</option>
                    {% for orga in organisations %}
                        <option value="{{ orga.id }}" {% if selectedOwner == orga.id %}selected{% endif %}>
                            {{ orga.name }}
                        </option>
                    {% endfor %}
                </select>
            </form>
        </div>
    </div>

    <div class="card">
        {% if applications is empty %}
            <p class="card__empty">Aucune application pour ce contexte.</p>
        {% else %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>ID</th>
                        <th>Zone</th>
                        <th>Branche</th>
                        <th>État</th>
                        <th class="table__actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for application in applications %}
                        <tr>
                            <td>
                                <a class="table__name" href="{{ path('application_show', selectedOwner ? { id: application.id, owner: selectedOwner } : { id: application.id }) }}">
                                    {{ application.name }}
                                </a>
                                {% if application.favourite %}<span title="Favori"> ⭐</span>{% endif %}
                                {% if application.archived %}<span class="badge warn">archivée</span>{% endif %}
                            </td>
                            <td class="table__id-cell"><span class="table__id" title="{{ application.id }}">{{ application.id }}</span></td>
                            <td>{{ application.zone ?? '—' }}</td>
                            <td>{{ application.branch ?? '—' }}</td>
                            <td>
                                {% if application.state %}
                                    <span class="badge {{ application.state|cc_state_variant }}">
                                        {{ application.state|cc_state_label }}
                                    </span>
                                {% else %}—{% endif %}
                            </td>
                            <td class="table__actions">
                                <div class="btn-group">
                                    <form class="inline" method="post" action="{{ path('application_restart', { id: application.id }) }}">
                                        {% if selectedOwner %}<input type="hidden" name="owner" value="{{ selectedOwner }}">{% endif %}
                                        <button class="btn btn--primary btn--sm" type="submit">Redéployer</button>
                                    </form>
                                    <form class="inline" method="post" action="{{ path('application_stop', { id: application.id }) }}"
                                          onsubmit="return confirm('Arrêter {{ application.name }} ?')">
                                        {% if selectedOwner %}<input type="hidden" name="owner" value="{{ selectedOwner }}">{% endif %}
                                        <button class="btn btn--danger btn--sm" type="submit">Stop</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
