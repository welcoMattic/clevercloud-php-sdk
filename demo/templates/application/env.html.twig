{% extends 'base.html.twig' %}

{% block title %}Env — {{ application.name }} — Clever Cloud Dashboard{% endblock %}
{% block page_title %}Variables d'environnement{% endblock %}
{% block page_subtitle %}
    <p class="topbar__subtitle">{{ application.name }} · <span class="table__id">{{ application.id }}</span></p>
{% endblock %}

{% block body %}
    <a class="back-link" href="{{ path('application_show', owner ? { id: application.id, owner: owner } : { id: application.id }) }}">← Retour à l'application</a>

    <div class="card">
        <div class="card__header"><h3 class="card__title">Ajouter / mettre à jour une variable</h3></div>
        <div class="card__body">
            <form method="post" action="{{ path('application_env_set', { id: application.id }) }}" class="form-row">
                {% if owner %}<input type="hidden" name="owner" value="{{ owner }}">{% endif %}
                <div class="form-field" style="flex: 1;">
                    <label class="form-field__label" for="env-name">Nom</label>
                    <input id="env-name" name="name" type="text" required placeholder="DATABASE_URL"
                           class="form-field__input form-field__input--mono">
                </div>
                <div class="form-field" style="flex: 2;">
                    <label class="form-field__label" for="env-value">Valeur</label>
                    <input id="env-value" name="value" type="text" placeholder="postgres://..."
                           class="form-field__input form-field__input--mono">
                </div>
                <button type="submit" class="btn btn--primary">Enregistrer</button>
            </form>
            <p class="form-help" style="margin-top: 0.6rem;">
                L'enregistrement est immédiat côté API. La valeur n'est appliquée qu'au prochain redéploiement.
            </p>
        </div>
    </div>

    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Variables actuelles{% if env %} <span class="badge neutral">{{ env|length }}</span>{% endif %}</h3>
        </div>
        {% if env is empty %}
            <p class="card__empty">Aucune variable d'environnement.</p>
        {% else %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Valeur</th>
                        <th class="table__actions">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for name, value in env %}
                        <tr>
                            <td><code class="code">{{ name }}</code></td>
                            <td>
                                <details>
                                    <summary style="cursor: pointer; color: var(--color-text-muted); font-size: 0.85rem;">
                                        {{ value|length }} caractères — afficher
                                    </summary>
                                    <code class="code" style="display: block; margin-top: 0.4rem; word-break: break-all;">{{ value }}</code>
                                </details>
                            </td>
                            <td class="table__actions">
                                <div class="btn-group">
                                    <form class="inline" method="post" action="{{ path('application_env_set', { id: application.id }) }}"
                                          onsubmit="this.querySelector('input[name=value]').value = prompt('Nouvelle valeur pour {{ name }}', this.querySelector('input[name=value]').value); if (this.querySelector('input[name=value]').value === null) return false;">
                                        {% if owner %}<input type="hidden" name="owner" value="{{ owner }}">{% endif %}
                                        <input type="hidden" name="name" value="{{ name }}">
                                        <input type="hidden" name="value" value="{{ value }}">
                                        <button class="btn btn--sm" type="submit">Éditer</button>
                                    </form>
                                    <form class="inline" method="post" action="{{ path('application_env_remove', { id: application.id, name: name }) }}"
                                          onsubmit="return confirm('Supprimer {{ name }} ?')">
                                        {% if owner %}<input type="hidden" name="owner" value="{{ owner }}">{% endif %}
                                        <button class="btn btn--danger btn--sm" type="submit">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
